# Bunny Storage credentials.
# Create a Storage Zone at https://dash.bunny.net/storage and copy these values.

# The API key from Bunny dashboard: Storage Zone → FTP & API Access → "Password".
# SERVER-SIDE ONLY. Never prefix with PUBLIC_.
BUNNY_STORAGE_API_KEY=your-bunny-storage-password-here

# Storage Zone name (e.g. "my-zone").
BUNNY_STORAGE_ZONE=your-zone-name

# Storage region host. Defaults to storage.bunnycdn.com (no region).
# Regional hosts: la.storage.bunnycdn.com, ny.storage.bunnycdn.com,
# sg.storage.bunnycdn.com, syd.storage.bunnycdn.com, uk.storage.bunnycdn.com, etc.
BUNNY_STORAGE_HOST=storage.bunnycdn.com

# Public Pull Zone URL — what the browser fetches from. Linked to the storage zone
# in Bunny dashboard. Must have CORS enabled (Pull Zone → Headers → CORS, with
# "json" added to the allowed extensions list so metadata.json fetches succeed).
# PUBLIC_ prefix means SvelteKit exposes this to the browser bundle.
PUBLIC_BUNNY_CDN_BASE=https://your-zone.b-cdn.net
